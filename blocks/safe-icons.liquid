

{% liquid
  assign block_settings = block.settings
%}

<div
  class="safe-icons safe-icons--{{ block.id }} spacing-style"
  style="{% render 'spacing-padding', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  <ul class="safe-icons__list" role="list">
    {% for i in (1..3) %}
      {% liquid
        assign svg_key = 'badge_svg_' | append: i
        assign link_key = 'badge_link_' | append: i
        assign svg_content = block.settings[svg_key]
        assign link_url = block.settings[link_key]
      %}

      {% if svg_content != blank %}
        <li class="safe-icons__item">
          {%- if link_url != blank -%}
            <a href="{{ link_url }}" class="safe-icons__link" target="_blank" rel="noopener noreferrer">
          {%- endif -%}

          <div class="safe-icons__svg-wrapper">
            {{ svg_content }}
          </div>

          {%- if link_url != blank -%}
            </a>
          {%- endif -%}
        </li>
      {% else %}
        {% if request.design_mode %}
          <li class="safe-icons__item">
            <div class="safe-icons__placeholder">Icon {{ i }}</div>
          </li>
        {% endif %}
      {% endif %}
    {% endfor %}
  </ul>
</div>

{% style %}
  .safe-icons--{{ block.id }} {
    --icon-size-desktop: {{ block_settings.badge_size_desktop }}px;
    --icon-size-mobile: {{ block_settings.badge_size_mobile }}px;
    --gap-desktop: {{ block_settings.spacing_desktop }}px;
    --gap-mobile: {{ block_settings.spacing_mobile }}px;
    --alignment-desktop: {{ block_settings.alignment_desktop }};
    --alignment-mobile: {{ block_settings.alignment_mobile }};
    {% if block_settings.columns_mobile == '1' %}
      --flex-direction-mobile: column;
    {% else %}
      --flex-direction-mobile: row;
    {% endif %}
  }

  .safe-icons__list {
    display: flex;
    justify-content: var(--alignment-desktop);
    gap: var(--gap-desktop);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .safe-icons__item {
    display: flex;
  }
  .safe-icons__svg-wrapper {
    width: var(--icon-size-desktop);
    height: auto;
    color: {{ block_settings.badge_color }};
    transition: color 0.2s ease;
  }
  .safe-icons__link:hover .safe-icons__svg-wrapper {
    color: {{ block_settings.badge_hover_color }};
  }
  .safe-icons__svg-wrapper svg {
    display: block;
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
  .safe-icons__placeholder {
    width: var(--icon-size-desktop);
    height: var(--icon-size-desktop);
    background-color: #f4f4f4;
    border: 1px dashed #cccccc;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999999;
    font-size: 14px;
    text-align: center;
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .safe-icons__list {
      flex-direction: var(--flex-direction-mobile);
      justify-content: var(--alignment-mobile);
      gap: var(--gap-mobile);
    }
    .safe-icons__svg-wrapper,
    .safe-icons__placeholder {
      width: var(--icon-size-mobile);
    }
    .safe-icons__placeholder {
      height: var(--icon-size-mobile);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:names.safe_icons",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.badges"
    },
    {
      "type": "html",
      "id": "badge_svg_1",
      "label": "t:settings.badge_1.svg"
    },
    {
      "type": "url",
      "id": "badge_link_1",
      "label": "t:settings.badge_1.link"
    },
    {
      "type": "html",
      "id": "badge_svg_2",
      "label": "t:settings.badge_2.svg"
    },
    {
      "type": "url",
      "id": "badge_link_2",
      "label": "t:settings.badge_2.link"
    },
    {
      "type": "html",
      "id": "badge_svg_3",
      "label": "t:settings.badge_3.svg"
    },
    {
      "type": "url",
      "id": "badge_link_3",
      "label": "t:settings.badge_3.link"
    },
    {
      "type": "header",
      "content": "t:content.colors"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "t:settings.badge_color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "badge_hover_color",
      "label": "t:settings.badge_hover_color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "alignment_desktop",
      "label": "t:settings.alignment",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" },
        { "value": "space-between", "label": "t:options.space_between" },
        { "value": "space-around", "label": "t:options.space_around" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "badge_size_desktop",
      "label": "t:settings.badge_size",
      "min": 40,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "spacing_desktop",
      "label": "t:names.spacing",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "t:content.mobile_layout"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:settings.columns",
      "options": [
        { "value": "3", "label": "t:options.columns_3" },
        { "value": "1", "label": "t:options.columns_1" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "alignment_mobile",
      "label": "t:settings.alignment",
      "options": [
        { "value": "flex-start", "label": "t:options.left" },
        { "value": "center", "label": "t:options.center" },
        { "value": "flex-end", "label": "t:options.right" },
        { "value": "space-between", "label": "t:options.space_between" },
        { "value": "space-around", "label": "t:options.space_around" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "badge_size_mobile",
      "label": "t:settings.badge_size",
      "min": 30,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "label": "t:names.spacing",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.safe_icons",
      "category": "t:categories.footer"
    }
  ]
}
{% endschema %}
