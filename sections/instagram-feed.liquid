

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__content">
    {%- content_for 'blocks' -%}
  </div>

  <div class="resource-list__item">
    {% content_for 'block', type: '_instagram-card', id: 'static-instagram-card' %}
  </div>
  
</div>

{% schema %}
{
  "name": "t:names.instagram_feed",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "group"
    },
    {
      "type": "_divider"
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "avatar_image",
      "label": "t:settings.profile_pic"
    },
    {
      "type": "text",
      "id": "username",
      "label": "t:settings.username",
      "default": "username"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0, "max": 100, "step": 1, "unit": "px", "default": 32
    }
  ],
  "presets": [
    {
      "name": "t:names.instagram_feed",
      "category": "t:categories.storytelling",
      "settings": {},
      "blocks": {
        "group_Lg9LkF": {
          "type": "group",
          "name": "t:names.header",
          "settings": {
            "content_direction": "row",
            "vertical_on_mobile": true,
            "horizontal_alignment": "space-between",
            "vertical_alignment": "center",
            "gap": 16,
            "inherit_color_scheme": true
          },
          "blocks": {
            "heading": {
              "type": "text",
              "name": "t:names.title",
              "settings": {
                "text": "<h2>Instagram</h2>",
                "type_preset": "rte"
              }
            },
            "button": {
              "type": "button",
              "name": "t:names.button",
              "settings": {
                "label": "t:text_defaults.view_all_button_label",
                "open_in_new_tab": false,
                "style_class": "link",
                "width": "fit-content",
                "custom_width": 100,
                "width_mobile": "fit-content",
                "custom_width_mobile": 100
              }
            }
          },
          "block_order": ["heading", "button"]
        },
        "static-instagram-card": {
          "type": "_instagram-card",
          "name": "t:names.instagram_card",
          "static": true,
          "settings": {},
          "blocks": {},
          "block_order": []
        },
      },
      "block_order": ["group_Lg9LkF"]
    }
  ]
}
{% endschema %}